{
    "id": "org.kde.kigo",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kigo",
    "rename-icon": "kigo",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--socket=wayland"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/share/doc",
        "/share/man",
        "/share/qlogging-categories6"
    ],
    "modules": [
        {
            "name": "libkdegames",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/libkdegames-25.12.3.tar.xz",
                    "sha256": "64605a58b087a57dc504d8e7fa4d637b4d59fb91ba1b4ed60f96fc78568f141c",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/libkdegames-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "gnugo",
            "build-options": {
                "cflags": "-fcommon"
            },
            "sources": [
                {
                    "type": "archive",
                    "url": "https://ftp.gnu.org/gnu/gnugo/gnugo-3.8.tar.gz",
                    "sha256": "da68d7a65f44dcf6ce6e4e630b6f6dd9897249d34425920bfdd4e07ff1866a72",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1209,
                        "stable-only": true,
                        "url-template": "https://ftp.gnu.org/gnu/gnugo/gnugo-$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "kigo",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/kigo-25.12.3.tar.xz",
                    "sha256": "ca00c01a636d0a636dd11926dd6a8a018b2018c3877b445eec3cc1617b7f0a69",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kigo-$version.tar.xz"
                    }
                }
            ]
        }
    ]
